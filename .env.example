# Copy to .env and adjust. The CLI loads this automatically.

# --- LLM (local open-source default via Ollama) ---
LLM_PROVIDER=ollama
LLM_MODEL=gemma2:9b
# LLM_TEMPERATURE=0
# Commercial alternative (also: uv pip install langchain-anthropic):
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...

# --- Database ---
DATABASE_URL=sqlite:///./university.db

# --- LangSmith tracing (optional) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=university-agent
